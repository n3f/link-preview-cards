{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wpogc/open-graph-card",
	"title": "Open Graph Card",
	"category": "embed",
	"icon": "format-image",
	"description": "Display a card for any URL with Open Graph data.",
	"keywords": ["open graph", "card", "embed", "block"],
	"version": "0.1.0",
	"textdomain": "wpogc",
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"editorStyle": "file:./build/index.css",
	"attributes": {
		"url": {
			"type": "string",
			"default": ""
		},
		"ogTitle": {
			"type": "string",
			"default": ""
		},
		"ogDescription": {
			"type": "string",
			"default": ""
		},
		"ogImage": {
			"type": "string",
			"default": ""
		}
	}
}