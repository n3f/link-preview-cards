{
  "name": "wp-open-graph-card",
  "version": "0.1.0",
  "description": "WordPress plugin that replaces embeds with Open Graph cards",
  "scripts": {
    "start": "wp-env start",
    "stop": "wp-env stop",
    "destroy": "wp-env destroy",
    "reset": "wp-env reset",
    "test:unit": "wp-scripts test-unit-js",
    "test:php": "wp-env run tests-cli php /var/www/html/wp-content/plugins/wp-open-graph/tests/test-api.php",
    "test:php-local": "php tests/test-api.php",
    "shell": "wp-env run cli wp shell",
    "build": "wp-scripts build",
    "block-start": "wp-scripts start"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@wordpress/env": "^10.26.0",
    "@wordpress/scripts": "^30.19.0"
  }
}